# Скопіюйте цей файл як .env і додайте ваші значення

# 🔑 Telegram Bot Token від BotFather
# Отримайте на: https://t.me/BotFather
# Напишіть: /start → /newbot → виберіть ім'я
TELEGRAM_TOKEN=YOUR_TELEGRAM_TOKEN_HERE

# 🔑 Anthropic API Key для Claude
# Отримайте на: https://console.anthropic.com/
# Повинен починатися з sk-ant-
ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE
